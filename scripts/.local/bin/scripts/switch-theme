#!/usr/bin/env bash

THEME="$1"
THEME_DIR="$HOME/.config/themes/$THEME"

if [ ! -d "$THEME_DIR" ]; then
    echo "Theme not found"
    exit 1
fi

# Hypr
ln -sf "$THEME_DIR/backgrounds" ~/.config/hypr/

# Kitty
ln -sf "$THEME_DIR/kitty" ~/.config/

# Waybar
ln -sf "$THEME_DIR/waybar" ~/.config/

# Rofi
ln -sf "$THEME_DIR/rofi" ~/.config/

# Neovim
ln -sf "$THEME_DIR/nvim/color-scheme.lua" ~/.config/nvim/lua/plugins/

# Ghostty
ln -sf "$THEME_DIR/ghostty" ~/.config/

# Btop
ln -sf "$THEME_DIR/btop/btop.theme" ~/.config/btop/themes/btop.theme

# GTK
# ln -sf "$THEME_DIR/gtk/settings.ini" ~/.config/gtk-3.0/settings.ini

# Reload apps
killall waybar
waybar &

killall hyprpaper
hyprpaper &

hyprctl reload
